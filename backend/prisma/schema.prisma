generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  location  String?
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // e.g., Admin, Billing Staff, Lab, Pharmacy, HR, Accounts, Management
  permissions String[] // Array of permission strings
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id           String      @id @default(uuid())
  employeeId   String      @unique // Employee ID
  email        String?     @unique
  passwordHash String
  otpEnabled   Boolean     @default(false)
  otpSecret    String?
  isActive     Boolean     @default(true)
  
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id])
  
  branchId     String
  branch       Branch      @relation(fields: [branchId], references: [id])
  
  auditLogs    AuditLog[]
  employee     Employee?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Employee {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  
  firstName   String
  lastName    String
  department  String?
  designation String?
  
  // HR Module Expansions
  managerId       String?
  manager         Employee?   @relation("ManagerToEmployee", fields: [managerId], references: [id])
  directReports   Employee[]  @relation("ManagerToEmployee")
  
  mobile          String?
  email           String?
  joinDate        DateTime?
  employmentType  String      @default("FULL_TIME") // FULL_TIME, PART_TIME, CONTRACT
  emergencyContact String?
  emergencyPhone  String?
  customFields    Json?
  
  visits      Visit[]
  admissions  Admission[]
  attendances Attendance[]
  payrolls    Payroll[]

  hrDocuments     HrDocument[]
  onboardingTasks OnboardingTask[]
  ownedGoals      Goal[]      @relation("GoalOwner")
  givenFeedbacks  Feedback[]  @relation("FeedbackGiver")
  rcvdFeedbacks   Feedback[]  @relation("FeedbackReceiver")
  surveys         SurveyResponse[]
  interviews      InterviewSlot[] @relation("Interviewer")
  createdJobs     JobDefinition[] @relation("HiringManager")
  oneOnOnesAsMgr  OneOnOneAgenda[] @relation("MgrAgenda")
  oneOnOnesAsEmp  OneOnOneAgenda[] @relation("EmpAgenda")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  details   String?  // JSON string or extra details
  ipAddress String?
  timestamp DateTime @default(now())
}

// ----------------------------------------------------
// LAYER 1: PATIENT MANAGEMENT & BILLING
// ----------------------------------------------------

model Patient {
  id              String   @id @default(uuid())
  uhid            String   @unique // Unique Health ID
  firstName       String
  lastName        String
  age             Int
  dob             DateTime?
  gender          String
  bloodGroup      String?
  maritalStatus   String?
  
  mobile          String
  email           String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  
  emgName         String?
  emgRelation     String?
  emgMobile       String?
  
  tpaName         String?
  policyNo        String?
  insuranceValid  DateTime?
  coverageAmt     Float?
  
  referredBy      String?
  
  visits          Visit[]
  labOrders       LabOrder[]
  prescriptions   Prescription[]
  admissions      Admission[]
  referrals       Referral[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Visit {
  id              String   @id @default(uuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Employee @relation(fields: [doctorId], references: [id])
  
  department      String
  tokenNo         String
  status          String   @default("WAITING") // WAITING, IN_CONSULTATION, COMPLETED
  
  notes           String?
  symptoms        String?
  diagnosis       String?

  bills           Bill[]
  labOrders       LabOrder[]
  prescriptions   Prescription[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Bill {
  id              String   @id @default(uuid())
  billNo          String   @unique
  patientId       String?
  
  visitId         String?
  visit           Visit?   @relation(fields: [visitId], references: [id])

  admissionId     String?
  admission       Admission? @relation(fields: [admissionId], references: [id])
  
  type            String   // OPD_CONSULTATION, LAB_DIAGNOSTICS, PHARMACY, IPD_FINAL
  subTotal        Float
  gstAmount       Float
  discount        Float    @default(0)
  netPayable      Float
  
  paymentMode     String   // CASH, CARD, UPI, INSURANCE
  status          String   @default("UNPAID") // UNPAID, PAID, REFUNDED

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LabOrder {
  id              String   @id @default(uuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  
  visitId         String?
  visit           Visit?   @relation(fields: [visitId], references: [id])
  
  testName        String
  sacCode         String   @default("999316")
  price           Float
  priority        String   @default("ROUTINE") // ROUTINE, HIGH, STAT
  status          String   @default("PENDING") // PENDING, SAMPLE_COLLECTED, RESULT_ENTERED
  
  resultText      String?
  resultValue     Float?   // Numeric value for critical range checks
  reportPdfUrl    String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Prescription {
  id              String   @id @default(uuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  
  visitId         String
  visit           Visit    @relation(fields: [visitId], references: [id])

  medicines       Json     // Array of { drugName, dosage, frequency, days }
  status          String   @default("PENDING") // PENDING, DISPENSED

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ----------------------------------------------------
// LAYER 2: IPD (IN-PATIENT) BILLING & WARD MANAGEMENT
// ----------------------------------------------------

model Ward {
  id              String   @id @default(uuid())
  name            String   // e.g., ICU, General Male, NICU
  type            String   // GENERAL, SEMI_PRIVATE, PRIVATE, ICU
  capacity        Int      // Number of beds
  
  beds            Bed[]    // Relation to beds
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Bed {
  id              String   @id @default(uuid())
  bedNumber       String
  wardId          String
  ward            Ward     @relation(fields: [wardId], references: [id])
  dailyRent       Float    // Daily charge for this specific bed
  status          String   @default("AVAILABLE") // AVAILABLE, OCCUPIED, MAINTENANCE
  
  admissions      Admission[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Admission {
  id              String   @id @default(uuid())
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  
  doctorId        String
  doctor          Employee @relation(fields: [doctorId], references: [id])
  
  bedId           String
  bed             Bed      @relation(fields: [bedId], references: [id])
  
  status          String   @default("ADMITTED") // ADMITTED, DISCHARGED
  
  admissionDate   DateTime @default(now())
  dischargeDate   DateTime?
  
  depositAmount   Float    @default(0)
  
  ipdCharges      IpdCharge[]
  bills           Bill[]     // Final settlement bill

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model IpdCharge {
  id              String   @id @default(uuid())
  admissionId     String
  admission       Admission @relation(fields: [admissionId], references: [id])
  
  chargeType      String   // ROOM_RENT, DOCTOR_VISIT, NURSING, SURGERY_OT, DIET, PHARMACY, CONSUMABLE
  description     String
  amount          Float
  dateAdded       DateTime @default(now())
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ----------------------------------------------------
// LAYER 3: LAB DIAGNOSTICS & PHARMACY INVENTORY
// ----------------------------------------------------

model LabCatalog {
  id              String   @id @default(uuid())
  testName        String   @unique
  department      String   // Hematology, Biochemistry, Microbiology
  price           Float
  unit            String?  // e.g., mg/dL, mmol/L
  criticalMin     Float?   // Lower bound for critical alert
  criticalMax     Float?   // Upper bound for critical alert
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ----------------------------------------------------
// CROSS-MODULE: NOTIFICATIONS & REFERRALS
// ----------------------------------------------------

model Notification {
  id              String   @id @default(uuid())
  targetUserId    String   // The user who should see this
  type            String   // LAB_RESULT, CRITICAL_ALERT, ADMISSION, REFERRAL, PRESCRIPTION
  title           String
  body            String
  priority        String   @default("NORMAL") // NORMAL, HIGH, CRITICAL
  isRead          Boolean  @default(false)
  
  visitId         String?
  labOrderId      String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Referral {
  id              String   @id @default(uuid())
  fromDoctorId    String
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  referralToken   String   @unique @default(uuid())
  toHospital      String   // Name/ID of destination hospital
  reason          String
  status          String   @default("PENDING") // PENDING, ACCEPTED, COMPLETED
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MedicineInventory {
  id              String   @id @default(uuid())
  drugName        String   @unique
  manufacturer    String?
  batchNo         String
  expiryDate      DateTime
  stockQuantity   Int      @default(0)
  unitPrice       Float
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ----------------------------------------------------
// LAYER 4: HR MODULE
// ----------------------------------------------------

model Attendance {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  
  date        DateTime @default(now())
  status      String   // PRESENT, ABSENT, HALF_DAY, LEAVE
  checkIn     DateTime?
  checkOut    DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([employeeId, date])
}

model Payroll {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  
  month       Int
  year        Int
  
  basicSalary Float
  allowances  Float    @default(0)
  deductions  Float    @default(0)
  netSalary   Float
  
  status      String   @default("PENDING") // PENDING, PAID
  paymentDate DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([employeeId, month, year])
}

// ----------------------------------------------------
// LAYER 5: ACCOUNTS, EXPENSES & GST/TDS COMPLIANCE
// ----------------------------------------------------

model Ledger {
  id          String    @id @default(uuid())
  name        String    @unique // e.g. "Bank A/c", "Cash A/c", "Sales A/c", "Salary A/c"
  group       String    // ASSET, LIABILITY, INCOME, EXPENSE
  balance     Float     @default(0) // Simplistic balance mapping
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Expense {
  id          String    @id @default(uuid())
  voucherNo   String    @unique
  category    String    // RENT, MAINTENANCE, UTILITIES, VENDOR_PAYMENT, MISC
  description String
  
  amount      Float
  gstAmount   Float     @default(0) // Input Tax Credit (ITC)
  tdsAmount   Float     @default(0) // TDS Deducted from vendor
  netAmount   Float     // amount + gstAmount - tdsAmount
  
  paymentMode String    // BANK, CASH, UPI, CREDIT
  status      String    @default("PENDING") // PENDING, PAID
  date        DateTime  @default(now())

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ----------------------------------------------------
// LAYER 6: EXTENDED HR (GUDHR SYSTEM)
// ----------------------------------------------------

model HrDocument {
  id          String   @id @default(uuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  title       String
  url         String
  type        String   // CONTRACT, POLICY, ID_PROOF
  status      String   @default("PENDING") // PENDING, SIGNED, VERIFIED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OnboardingWorkflow {
  id          String   @id @default(uuid())
  name        String
  description String?
  tasks       OnboardingTask[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model OnboardingTask {
  id          String   @id @default(uuid())
  workflowId  String
  workflow    OnboardingWorkflow @relation(fields: [workflowId], references: [id])
  
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  
  taskName    String
  assignedTo  String   // IT, HR, MANAGER, SELF
  status      String   @default("PENDING") // PENDING, COMPLETED
  dueDate     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Talent Acquisition
model JobDefinition {
  id              String   @id @default(uuid())
  title           String
  department      String
  description     String
  keywords        String?  // AI suggested keywords
  status          String   @default("DRAFT") // DRAFT, PUBLISHED, CLOSED
  
  hiringManagerId String
  hiringManager   Employee @relation("HiringManager", fields: [hiringManagerId], references: [id])
  
  candidates      Candidate[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Candidate {
  id          String   @id @default(uuid())
  jobId       String
  job         JobDefinition @relation(fields: [jobId], references: [id])
  
  firstName   String
  lastName    String
  email       String
  resumeUrl   String?
  status      String   @default("APPLIED") // APPLIED, SCREENING, INTERVIEW, OFFERED, HIRED, REJECTED
  
  scorecards  InterviewScorecard[]
  interviews  InterviewSlot[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InterviewSlot {
  id            String   @id @default(uuid())
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  
  interviewerId String
  interviewer   Employee @relation("Interviewer", fields: [interviewerId], references: [id])
  
  scheduledAt   DateTime
  durationMins  Int      @default(45)
  meetingLink   String?
  status        String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELED
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model InterviewScorecard {
  id            String   @id @default(uuid())
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id])
  
  interviewerId String
  
  competencies  Json     // { "technical": 4, "culture": 5, ... }
  notes         String?
  recommendation String  // STRONG_HIRE, HIRE, NO_HIRE
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Performance & Engagement
model Goal {
  id            String   @id @default(uuid())
  title         String
  level         String   // COMPANY, DEPARTMENT, TEAM, INDIVIDUAL
  
  ownerId       String?
  owner         Employee? @relation("GoalOwner", fields: [ownerId], references: [id])
  
  parentGoalId  String?
  parentGoal    Goal?    @relation("GoalHierarchy", fields: [parentGoalId], references: [id])
  subGoals      Goal[]   @relation("GoalHierarchy")
  
  progress      Int      @default(0) // 0-100%
  keyResults    Json?    // Array of key results
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Feedback {
  id            String   @id @default(uuid())
  fromUserId    String
  fromUser      Employee @relation("FeedbackGiver", fields: [fromUserId], references: [id])
  
  toUserId      String
  toUser        Employee @relation("FeedbackReceiver", fields: [toUserId], references: [id])
  
  content       String
  type          String   @default("PUBLIC") // PUBLIC, PRIVATE
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OneOnOneAgenda {
  id          String   @id @default(uuid())
  managerId   String
  manager     Employee @relation("MgrAgenda", fields: [managerId], references: [id])
  
  employeeId  String
  employee    Employee @relation("EmpAgenda", fields: [employeeId], references: [id])
  
  date        DateTime
  topics      Json?    // Added by manager/employee
  actionItems Json?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Survey {
  id          String   @id @default(uuid())
  title       String
  questions   Json     // List of questions
  status      String   @default("ACTIVE") // ACTIVE, CLOSED
  
  responses   SurveyResponse[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SurveyResponse {
  id          String   @id @default(uuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id])
  
  employeeId  String?  // Optional for anonymity tracking if needed (usually null)
  employee    Employee? @relation(fields: [employeeId], references: [id])
  
  answers     Json     // Answer payload corresponding to questions
  sentiment   String?  // AI Analyzed sentiment (e.g. POSITIVE, NEUTRAL, NEGATIVE)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
